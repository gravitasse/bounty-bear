{
  "version": 2,
  "name": "bounty-bear",
  "rewrites": [
    { "source": "/", "destination": "/web-demo/bounty-bear.html" },
    { "source": "/audio/(.*)", "destination": "/web-demo/audio/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
